---
const baseUrl = import.meta.env.BASE_URL
---

<header class="border-b border-zinc-200 dark:border-zinc-800">
	<nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 sm:px-6" aria-label="Main">
		<a
			href={baseUrl}
			class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors"
		>
			@just-web/foundation
		</a>
		<div class="flex gap-6">
			<a
				href={`${baseUrl}css/`}
				class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
			>
				@just-web/css
			</a>
			<a
				href={`${baseUrl}types/`}
				class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
			>
				@just-web/types
			</a>
			<a
				href={`${baseUrl}toolkits/`}
				class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
			>
				@just-web/toolkits
			</a>
			<a
				href="https://github.com/justland/just-web-foundation"
				target="_blank"
				rel="noopener noreferrer"
				class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
			>
				GitHub
			</a>
		</div>
	</nav>
</header>
