---
const baseUrl = import.meta.env.BASE_URL
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 mt-24">
	<div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
		<div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
			<p class="text-sm text-zinc-600 dark:text-zinc-400">MIT License</p>
			<nav class="flex gap-6" aria-label="Footer">
				<a
					href="https://github.com/justland/just-web-foundation"
					target="_blank"
					rel="noopener noreferrer"
					class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
				>
					GitHub
				</a>
				<a
					href={`${baseUrl}css/`}
					class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
				>
					@just-web/css
				</a>
				<a
					href={`${baseUrl}types/`}
					class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
				>
					@just-web/types
				</a>
				<a
					href={`${baseUrl}toolkits/`}
					class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
				>
					@just-web/toolkits
				</a>
			</nav>
		</div>
	</div>
</footer>
